{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": ["dist/**", ".output/**", ".vinxi/**", ".tanstack/**", "generated/**"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"dependsOn": ["^build"]
		},
		"typecheck": {
			"dependsOn": ["^build"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"test:unit": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"test:integration": {
			"dependsOn": ["^build"]
		},
		"test:e2e": {
			"dependsOn": ["build"],
			"outputs": ["playwright-report/**", "test-results/**"]
		},
		"proto:generate": {
			"outputs": ["generated/**"]
		},
		"db:generate": {},
		"db:migrate": {},
		"db:seed": {}
	}
}
